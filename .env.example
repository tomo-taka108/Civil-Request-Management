APP_NAME="Civil Request Management"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tokyo
APP_URL=http://localhost:8081

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB接続（Laravelコンテナ内から見たMySQLサービス名 = mysql）
# DB_DATABASE/DB_USERNAME/DB_PASSWORD は docker-compose.yml の mysql コンテナが
# env_file: .env 経由で参照する。値を変える場合はDBボリュームを作り直すこと。
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=civil_request_management
DB_USERNAME=civil_request_app
DB_PASSWORD=civil_local_password
# mysql コンテナの root パスワード（アプリからは使わない。ローカル専用）
DB_ROOT_PASSWORD=root_local_password
# 文字コード・照合順序は本番（famigo-mysql相乗り）と揃える（infrastructure-design.md 3.1節）。
# utf8mb4_ja_0900_as_cs = 日本語対応・大文字小文字/アクセントを区別（as_cs）。
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_ja_0900_as_cs

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
